[email]
smtp_host = "localhost"
smtp_port = 25
from_addr = "from@example.com"
to_addr = "to@example.com"
errors_to = ["errors@example.com", "errors2@example.com"]

[paths]
images_dir = "images"
cache_dir = "last_known_good_cache"

# Comics are downloaded and emailed in the order listed here.
#
# downloader values:
#   gocomics  - Playwright-based (for JavaScript-heavy gocomics.com pages)
#   thefarside - requests+BS4 (special: 2 images + optional captions)
#   arcamax   - requests+BS4 (BC, Bizarro, Jerry King, Fortune Teller)
#   xkcd      - requests+BS4
#   creators  - requests+BS4 (Wizard of Id)
#
# For gocomics entries, 'selector' is the CSS selector for the comic image.
# If the site redesigns and the selector breaks, update it here — no code change needed.
# The downloader also tries several fallback selectors automatically.

[[comics]]
id = "tfs"
name = "The Far Side"
downloader = "thefarside"
url = "https://www.thefarside.com/"
prefix = "tfs"
extension = "jpg"
max_images = 2

[[comics]]
id = "otm"
name = "Off the Mark"
downloader = "gocomics"
url = "https://www.gocomics.com/offthemark"
prefix = "otm"
extension = "gif"
selector = 'img[src*="featureassets.gocomics.com"]'

[[comics]]
id = "dh"
name = "Daddy's Home"
downloader = "gocomics"
url = "https://www.gocomics.com/daddyshome"
prefix = "dh"
extension = "gif"
selector = 'img[src*="featureassets.gocomics.com"]'

